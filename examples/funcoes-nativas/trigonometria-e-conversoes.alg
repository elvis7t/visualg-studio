algoritmo "TrigonometriaEConversoes"

// Exemplo de funcoes nativas de trigonometria e conversao.

var
  texto: caracter
  numero: inteiro

inicio
  texto <- "123"
  numero <- caracpnum(texto)

  escreval("arcsen(0): ", arcsen(0))
  escreval("arccos(1): ", arccos(1))
  escreval("cotan(1): ", cotan(1):1:3)
  escreval("texto convertido + 7: ", numero + 7)
  escreval("numero como texto: ", numpcarac(42))
fimalgoritmo
