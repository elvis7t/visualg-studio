{
  "name": "visualg-studio",
  "version": "0.1.0",
  "public": true,
  "type": "module",
  "description": "Modern Electron studio for Visualg algorithms.",
  "main": "src/main/main.js",
  "productName": "VisuAlg Studio",
  "author": "Elvis Leite da Silva",
  "license": "MIT",
  "keywords": [
    "visualg",
    "nodejs",
    "electron",
    "algoritmos",
    "educação",
    "studio"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elvis7t/visualg-studio.git"
  },
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "build:renderer": "esbuild src/renderer/app.js --bundle --format=esm --outfile=src/renderer/bundle.js",
    "pack": "npm run build:renderer && electron-builder --dir",
    "pack:win": "npm run build:renderer && electron-builder --win --dir",
    "dist": "npm run build:renderer && electron-builder",
    "dist:win": "npm run build:renderer && electron-builder --win",
    "dist:linux": "npm run build:renderer && electron-builder --linux",
    "generate:icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "check": "node scripts/check-syntax.js",
    "verify": "npm test && npm run check",
    "test": "node --test",
    "test:watch": "node --test --watch"
  },
  "build": {
    "appId": "br.com.visualg.studio",
    "productName": "VisuAlg Studio",
    "icon": "resources/icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "elvis7t",
        "repo": "visualg-studio"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "src/**/*",
      "examples/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VisuAlg Studio"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "electron-updater": "^6.8.3"
  }
}
